@model StudentHelper.Web.Models.Calendar.CreatePersonalEventViewModel

@{
	ViewData["Title"] = "Створення події";
}

<div class="form-page">
	<div class="form-card">
		<div class="form-card-title">Нова подія</div>

		<form asp-action="Create" method="post">
			<div asp-validation-summary="ModelOnly" class="validation"></div>

			<div class="form-grid">
				<div class="form-group full">
					<label asp-for="Title">Назва</label>
					<input asp-for="Title" placeholder="Додайте назву" />
					<span asp-validation-for="Title" class="validation"></span>
				</div>

				<div class="form-group">
					<label asp-for="Date">Дата</label>
					<input asp-for="Date" />
					<span asp-validation-for="Date" class="validation"></span>
				</div>

				<div class="form-group">
					<label>Тип події</label>
					<select>
						<option selected>Особисте</option>
						<option disabled>Навчальне</option>
					</select>
				</div>

				<div class="form-group">
					<label asp-for="StartTime">Час початку</label>
					<input asp-for="StartTime" />
					<span asp-validation-for="StartTime" class="validation"></span>
				</div>

				<div class="form-group">
					<label asp-for="EndTime">Час завершення</label>
					<input asp-for="EndTime" />
					<span asp-validation-for="EndTime" class="validation"></span>
				</div>

				<div class="form-group full">
					<label asp-for="Description">Деталі події</label>
					<textarea asp-for="Description" placeholder="Введіть опис"></textarea>
					<span asp-validation-for="Description" class="validation"></span>
				</div>
			</div>

			<div class="form-actions">
				<button type="submit" class="primary-btn">Зберегти</button>
				<a asp-action="Index" class="secondary-btn">Скасувати</a>
			</div>
		</form>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}
