@model IEnumerable<StudentHelper.Domain.Entities.PersonalEvent>

@{
    ViewData["Title"] = "Мої події";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">Мої події</h1>
        <a asp-action="Create" class="btn btn-primary">Додати подію</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <p class="text-muted">У вас ще немає створених подій.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                <div class="col-12">
                    <div class="bg-white rounded-4 shadow-sm p-4 border-start border-4 border-info">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h4 class="fw-bold mb-1">@item.Title</h4>
                                <p class="text-secondary mb-2">@item.Description</p>
                                <div class="badge bg-light text-dark border">
                                     @item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Редагувати</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Видалити</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>