<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Helper</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    
    <link rel="stylesheet" href="~/css/bundle.min.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="~/StudentHelper.Web.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">Student Helper</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Calendar" asp-action="Index">Календар</a></li>
                            @if (!User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Tasks" asp-action="Index">Завдання</a></li>
                            }
                            <li class="nav-item"><a class="nav-link" asp-controller="Notes" asp-action="Index">Нотатки</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Exams" asp-action="Index">Екзамени</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="AboutApp">Про додаток</a></li>
                            
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="UserRequests" asp-action="@(User.IsInRole("Admin") ? "AdminIndex" : "Index")">Звернення</a>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Students" asp-action="Index">Студенти</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Groups" asp-action="Index">Групи</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Schedule" asp-action="Index">Розклад</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Schedule" asp-action="Create">Створити розклад</a></li>
                            }
                        }
                    </ul>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <div class="dropdown">
                                <button class="notification-button btn btn-link position-relative" type="button" id="notificationBell" data-bs-toggle="dropdown">
                                    <i class="bi bi-bell fs-5"></i>
                                    <span id="notification-unread-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">0</span>
                                </button>
                                <div class="notification-panel dropdown-menu dropdown-menu-end shadow" id="notification-panel">
                                    <p class="text-muted text-center p-3 m-0">Немає нотифікацій</p>
                                </div>
                            </div>

                            <div class="dropdown">
                                <button class="btn btn-link dropdown-toggle text-dark text-decoration-none" type="button" id="userMenu" data-bs-toggle="dropdown">
                                    @User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius: 12px;">
                                    <li>
                                        <a class="dropdown-item py-2 d-flex align-items-center" asp-controller="Settings" asp-action="Index">
                                            <i class="bi bi-gear me-2"></i> Налаштування
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-controller="Account" asp-action="Logout" id="logoutForm">
                                            <button type="submit" class="dropdown-item py-2 d-flex align-items-center border-0 bg-transparent w-100 text-start">
                                                <i class="bi bi-box-arrow-right me-2"></i> Вихід
                                            </button>
                                        </form>
                                    </li>
                                </ul>                                
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Login">Вхід</a>
                            <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Register">Реєстрація</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-5">
        @RenderBody()
    </main>

    <footer class="border-top text-muted bg-light py-4 mt-auto">
        <div class="container text-center">
            <p class="mb-1">&copy; 2026 Student Helper - <a asp-controller="Home" asp-action="Privacy">Конфіденційність</a></p>
            <small>Офіційна платформа для управління навчанням</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
    
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>

    <script src="~/js/site.min.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>