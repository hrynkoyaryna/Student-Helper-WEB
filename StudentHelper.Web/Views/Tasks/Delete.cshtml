@model StudentHelper.Domain.Entities.TaskItem

@{
    ViewData["Title"] = "Видалення завдання";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
                <div class="card-header bg-danger text-white p-4 border-0 text-center">
                    <h2 class="mb-0 fw-bold">Видалення завдання</h2>
                </div>

                <div class="card-body p-5 bg-white text-center">
                    <p class="lead mb-4">Ви впевнені, що хочете видалити це завдання? <br> 
                       <small class="text-muted">Цю дію неможливо буде скасувати.</small>
                    </p>

                    <div class="text-start bg-light rounded-4 p-4 mb-4 border">
                        <div class="mb-3">
                            <h6 class="text-muted fw-bold text-uppercase small mb-1">Назва</h6>
                            <p class="h5 fw-bold">@Model.Title</p>
                        </div>

                        <div class="mb-3">
                            <h6 class="text-muted fw-bold text-uppercase small mb-1">Предмет</h6>
                            <p class="mb-0">@Model.Subject</p>
                        </div>

                        <div class="row">
                            <div class="col-6">
                                <h6 class="text-muted fw-bold text-uppercase small mb-1">Дедлайн</h6>
                                <p class="mb-0"> @Model.Deadline.ToString("dd.MM.yyyy HH:mm")</p>
                            </div>
                            <div class="col-6">
                                <h6 class="text-muted fw-bold text-uppercase small mb-1">Статус</h6>
                                <span class="badge @(Model.Status == "Done" ? "bg-success" : "bg-warning text-dark")">
                                    @Model.Status
                                </span>
                            </div>
                        </div>
                    </div>

                    @* Форма видалення *@
                    <form asp-action="Delete" method="post" asp-route-id="@Model.Id">
                        @Html.AntiForgeryToken()
                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
    <button type="submit" class="btn btn-danger px-5 fw-bold py-2 shadow-sm" style="border-radius: 10px;">
        Так, видалити
    </button>
    <a asp-action="Index" class="btn btn-outline-secondary px-5 fw-bold py-2" style="border-radius: 10px;">
        Скасувати
    </a> @* <-- Додано закриваючий тег *@
</div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }
    .card {
        animation: fadeIn 0.3s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>