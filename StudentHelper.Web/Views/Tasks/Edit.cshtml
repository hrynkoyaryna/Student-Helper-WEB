@model StudentHelper.Web.Models.Tasks.TaskCreateEditViewModel

@{
    ViewData["Title"] = "Редагувати завдання";
}

<div class="container py-5">
    <div class="bg-white rounded-4 shadow-sm p-4 mx-auto" style="max-width: 700px;">
        <h2 class="fw-bold mb-4">Редагувати завдання</h2>

        <form asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold">Назва</label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Subject" class="form-label fw-semibold">Предмет</label>
                <input asp-for="Subject" class="form-control" />
                <span asp-validation-for="Subject" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Deadline" class="form-label fw-semibold">Дедлайн</label>
                <input asp-for="Deadline" type="datetime-local" class="form-control" value="@Model.Deadline.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="Deadline" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Status" class="form-label fw-semibold">Статус</label>
                <select asp-for="Status" class="form-select">
                    <option value="Поточне">Поточне</option>
                    <option value="Виконане">Виконане</option>
                    <option value="Прострочене">Прострочене</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Зберегти</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}