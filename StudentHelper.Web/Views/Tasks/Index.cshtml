@model StudentHelper.Web.Models.Tasks.TaskIndexViewModel

@{
    ViewData["Title"] = "Завдання";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 style="font-size: 32px; font-weight: 800; color: rgb(26, 26, 26);">📝 Завдання</h1>
        <a asp-action="Create" class="btn btn-primary px-4">Додати завдання</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-4 shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["WarningMessage"] != null)
    {
        <div class="alert alert-warning rounded-4 shadow-sm">
            <i class="fas fa-exclamation-triangle"></i> @TempData["WarningMessage"]
        </div>
    }

    <div class="bg-white rounded-4 shadow-sm p-4">
        <div class="d-flex flex-wrap gap-2 mb-4">
            <a asp-action="Index"
               asp-route-status="Поточне"
               asp-route-subject="@Model.SelectedSubject"
               asp-route-searchTerm="@Model.SearchTerm"
               class="btn @(Model.SelectedStatus == "Поточне" ? "btn-primary" : "btn-outline-primary")">
                Поточні
            </a>

            <a asp-action="Index"
               asp-route-status="Виконане"
               asp-route-subject="@Model.SelectedSubject"
               asp-route-searchTerm="@Model.SearchTerm"
               class="btn @(Model.SelectedStatus == "Виконане" ? "btn-primary" : "btn-outline-primary")">
                Виконані
            </a>

            <a asp-action="Index"
               asp-route-status="Прострочене"
               asp-route-subject="@Model.SelectedSubject"
               asp-route-searchTerm="@Model.SearchTerm"
               class="btn @(Model.SelectedStatus == "Прострочене" ? "btn-primary" : "btn-outline-primary")">
                Прострочені
            </a>
        </div>

        <form method="get" asp-action="Index" class="row g-3 align-items-end mb-4">
            <input type="hidden" name="status" value="@Model.SelectedStatus" />

            <div class="col-md-4">
                <label class="form-label fw-semibold">Пошук</label>
                <input type="text"
                       id="searchInput"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       class="form-control"
                       placeholder="Введіть назву завдання" />
            </div>

            <div class="col-md-4">
                <label class="form-label fw-semibold">Предмет</label>
                <select name="subject" class="form-select">
                    <option value="">Усі предмети</option>
                    @foreach (var subject in Model.Subjects)
                    {
                        if (Model.SelectedSubject == subject)
                        {
                            <option value="@subject" selected>@subject</option>
                        }
                        else
                        {
                            <option value="@subject">@subject</option>
                        }
                    }
                </select>
            </div>

            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary">Фільтрувати</button>
            </div>

            <div class="col-md-auto">
                <a asp-action="Index" asp-route-status="@Model.SelectedStatus" class="btn btn-outline-secondary">Скинути</a>
            </div>
        </form>

        @if (!Model.Tasks.Any())
        {
            <div class="text-center py-5 text-secondary">
                <h5 class="mb-2">Немає завдань</h5>
                <p class="mb-0">Додай нове завдання або зміни фільтр.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var task in Model.Tasks)
                {
                    <div class="col-12">
                        <div class="border rounded-4 p-4 shadow-sm">
                            <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                                <div>
                                    <h4 class="mb-2">@task.Title</h4>
                                    <div class="text-secondary mb-1">
                                        <strong>Предмет:</strong> @task.Subject
                                    </div>
                                    <div class="text-secondary mb-1">
                                        <strong>Дедлайн:</strong> @task.Deadline.ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                    <div>
                                        <span class="badge bg-info text-dark">@task.Status</span>
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap gap-2 align-items-start">
                                    <a asp-action="Details" asp-route-id="@task.Id" class="btn btn-outline-secondary btn-sm">Деталі</a>
                                    <a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-outline-primary btn-sm">Редагувати</a>
                                    <a asp-action="Delete" asp-route-id="@task.Id" class="btn btn-outline-danger btn-sm">Видалити</a>

                                    <form asp-action="ChangeStatus" method="post" class="d-flex gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@task.Id" />
                                        <select name="status" class="form-select form-select-sm">
                                            @if (task.Status == "Поточне")
                                            {
                                                <option value="Поточне" selected>Поточне</option>
                                            }
                                            else
                                            {
                                                <option value="Поточне">Поточне</option>
                                            }

                                            @if (task.Status == "Виконане")
                                            {
                                                <option value="Виконане" selected>Виконане</option>
                                            }
                                            else
                                            {
                                                <option value="Виконане">Виконане</option>
                                            }

                                            @if (task.Status == "Прострочене")
                                            {
                                                <option value="Прострочене" selected>Прострочене</option>
                                            }
                                            else
                                            {
                                                <option value="Прострочене">Прострочене</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-primary btn-sm">Оновити</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        
        @* Пагінація *@
        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Навігація по сторінках" class="mt-4">
                <ul class="pagination justify-content-center">
                    @* Кнопка "Попередня" *@
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index" 
                               asp-route-status="@Model.SelectedStatus" 
                               asp-route-subject="@Model.SelectedSubject"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-page="@(Model.CurrentPage - 1)" 
                               aria-label="Попередня сторінка">
                                ← Попередня
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">← Попередня</span>
                        </li>
                    }

                    @* Номери сторінок *@
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (i == Model.CurrentPage)
                        {
                            <li class="page-item active" aria-current="page">
                                <span class="page-link">
                                    @i
                                    <span class="visually-hidden">(поточна)</span>
                                </span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" asp-action="Index"
                                   asp-route-status="@Model.SelectedStatus"
                                   asp-route-subject="@Model.SelectedSubject"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-page="@i">
                                    @i
                                </a>
                            </li>
                        }
                    }

                    @* Кнопка "Наступна" *@
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" asp-action="Index"
                               asp-route-status="@Model.SelectedStatus"
                               asp-route-subject="@Model.SelectedSubject"
                               asp-route-searchTerm="@Model.SearchTerm"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               aria-label="Наступна сторінка">
                                Наступна →
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="page-item disabled">
                            <span class="page-link">Наступна →</span>
                        </li>
                    }
                </ul>
            </nav>
            
            <div class="text-center text-muted small mt-2">
                Сторінка @Model.CurrentPage з @Model.TotalPages 
                (@Model.TotalItems елементів, по @Model.ItemsPerPage на сторінці)
            </div>
        }
    </div>
</div>
<script>
    let timeout = null;
    const searchInput = document.getElementById("searchInput");

    const savedCursorPosition = sessionStorage.getItem("taskSearchCursorPosition");
    const shouldFocus = sessionStorage.getItem("taskSearchFocus");

    if (searchInput && shouldFocus === "true")
    {
        searchInput.focus();

        if (savedCursorPosition !== null)
        {
            const position = parseInt(savedCursorPosition, 10);
            searchInput.setSelectionRange(position, position);
        }

        sessionStorage.removeItem("taskSearchFocus");
        sessionStorage.removeItem("taskSearchCursorPosition");
    }

    searchInput.addEventListener("input", function () {
        clearTimeout(timeout);

        timeout = setTimeout(() => {
            sessionStorage.setItem("taskSearchFocus", "true");
            sessionStorage.setItem("taskSearchCursorPosition", searchInput.selectionStart);
            this.form.submit();
        }, 400);
    });
</script>