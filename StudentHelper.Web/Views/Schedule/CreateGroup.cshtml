<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                <div class="card-header border-0 py-3 text-center" style="background-color: rgb(91, 200, 216);">
                    <h4 class="text-white mb-0">Створити нову групу</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
                    }
                    <form asp-action="CreateGroup" method="post">
                        <div class="mb-4">
                            <label class="form-label" style="font-weight: 600;">Назва групи</label>
                            <input type="text" name="name" class="form-control shadow-none" placeholder="Наприклад, ПІ-33" required style="border-radius: 8px;" />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn text-white flex-grow-1" style="background-color: rgb(91, 200, 216); border-radius: 10px;">Створити</button>
                            <a asp-action="Create" class="btn btn-outline-secondary flex-grow-1" style="border-radius: 10px;">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>