@model StudentHelper.Web.Models.Schedule.CreateScheduleViewModel

@{
    ViewData["Title"] = "Створення графіка";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                <div class="card-header border-0 py-3" style="background-color: rgb(91, 200, 216); border-radius: 15px 15px 0 0;">
                    <h3 class="card-title text-white mb-0 text-center">
                        <i class="bi bi-calendar-plus me-2"></i>Створити графік
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- ОСНОВНИЙ РЯД: Введення з клавіатури -->
                        <div class="row">
                            <!-- Група (вибір з існуючих) -->
                            <div class="col-md-4 mb-3">
                                <label asp-for="GroupId" class="form-label fw-bold">Група</label>
                                <select asp-for="GroupId" class="form-select shadow-none" asp-items="Model.Groups" style="border-radius: 8px;">
                                    <option value="">-- Оберіть групу --</option>
                                </select>
                                <span asp-validation-for="GroupId" class="text-danger small"></span>
                            </div>

                            <!-- ПРЕДМЕТ (ВРУЧНУ З КЛАВІАТУРИ) -->
                            <div class="col-md-4 mb-3">
                                <label asp-for="SubjectTitle" class="form-label fw-bold">Предмет</label>
                                <input asp-for="SubjectTitle" class="form-control shadow-none" placeholder="Введіть назву предмета" required style="border-radius: 8px;" />
                                <span asp-validation-for="SubjectTitle" class="text-danger small"></span>
                            </div>

                            <!-- ВИКЛАДАЧ (ВРУЧНУ З КЛАВІАТУРИ) -->
                            <div class="col-md-4 mb-3">
                                <label asp-for="TeacherFullName" class="form-label fw-bold">Викладач</label>
                                <input asp-for="TeacherFullName" class="form-control shadow-none" placeholder="Прізвище та ініціали" required style="border-radius: 8px;" />
                                <span asp-validation-for="TeacherFullName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mt-2">
                            <!-- Тип заняття -->
                            <div class="col-md-4 mb-3">
                                <label asp-for="LessonType" class="form-label fw-bold">Тип заняття</label>
                                <select asp-for="LessonType" class="form-select shadow-none" style="border-radius: 8px;">
                                    <option value="Лекція">Лекція</option>
                                    <option value="Практична">Практична</option>
                                    <option value="Лабораторна">Лабораторна</option>
                                    <option value="Семінар">Семінар</option>
                                </select>
                            </div>

                            <!-- Аудиторія -->
                            <div class="col-md-4 mb-3">
                                <label asp-for="Room" class="form-label fw-bold">Аудиторія</label>
                                <input asp-for="Room" class="form-control shadow-none" placeholder="Напр. 402 або Teams" style="border-radius: 8px;" />
                            </div>

                            <!-- Періодичність -->
                            <div class="col-md-4 mb-3">
                                <label asp-for="IsEvenWeek" class="form-label fw-bold">Періодичність тижня</label>
                                <select asp-for="IsEvenWeek" class="form-select shadow-none" style="border-radius: 8px;">
                                    <option value="">Кожен тиждень</option>
                                    <option value="true">Парний тиждень</option>
                                    <option value="false">Непарний тиждень</option>
                                </select>
                            </div>
                        </div>

                        <hr class="my-4 text-muted">

                        <!-- Ряд 3: Період генерації -->
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label fw-bold">Дата початку з</label>
                                <input asp-for="StartDate" type="date" class="form-control shadow-none" style="border-radius: 8px;" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label fw-bold">Дата закінчення</label>
                                <input asp-for="EndDate" type="date" class="form-control shadow-none" style="border-radius: 8px;" />
                            </div>
                        </div>

                        <!-- Ряд 4: День тижня та Час -->
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="DayOfWeek" class="form-label fw-bold">День тижня</label>
                                <select asp-for="DayOfWeek" class="form-select shadow-none" asp-items="Html.GetEnumSelectList<DayOfWeek>()" style="border-radius: 8px;"></select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="StartTime" class="form-label fw-bold">Час початку</label>
                                <input asp-for="StartTime" type="time" class="form-control shadow-none" style="border-radius: 8px;" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="EndTime" class="form-label fw-bold">Час завершення</label>
                                <input asp-for="EndTime" type="time" class="form-control shadow-none" style="border-radius: 8px;" />
                            </div>
                        </div>

                        <div class="mt-4 d-grid gap-2">
                            <button type="submit" class="btn text-white py-2 shadow-sm" style="background-color: rgb(91, 200, 216); border-radius: 10px; font-weight: 600;">
                                <i class="bi bi-check-all me-2"></i>Створити графік
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary py-2" style="border-radius: 10px;">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}