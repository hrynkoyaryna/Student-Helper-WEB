@model StudentHelper.Web.Models.Schedule.CreateScheduleViewModel

@{
    ViewData["Title"] = "Створення розкладу";
}

<div class="card">
    <div class="card-body">
        <h3>Створити розклад для групи</h3>
        
        <div class="alert alert-info" role="alert">
            <strong>Обов'язкові поля:</strong> Група, Предмет, Дата, Час, Викладач
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                <strong>Помилка:</strong> @TempData["ErrorMessage"]
            </div>
        }

        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            
            <!-- GROUP SECTION -->
            <div class="row">
                <div class="col-md-5 mb-3">
                    <label asp-for="GroupId" class="form-label">
                        <span class="text-danger">*</span> Група (вибір)
                    </label>
                    <select asp-for="GroupId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Groups, "Id", "Name", Model.GroupId))">
                        <option value="">-- Виберіть групу --</option>
                    </select>
                    <span asp-validation-for="GroupId" class="text-danger"></span>
                    <small class="text-muted">Або введіть нову групу нижче</small>
                </div>

                <div class="col-md-5 mb-3">
                    <label asp-for="GroupName" class="form-label">Група (нова)</label>
                    <input asp-for="GroupName" class="form-control" placeholder="Напр. ПМІ-31" />
                    <small class="text-muted">Якщо вибрали групу вище, це поле ігнорується</small>
                </div>
            </div>
            
            <!-- SUBJECT SECTION -->
            <div class="row">
                <div class="col-md-5 mb-3">
                    <label asp-for="SubjectId" class="form-label">
                        <span class="text-danger">*</span> Предмет
                    </label>
                    <select asp-for="SubjectId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Subjects, "Id", "Title", Model.SubjectId))">
                        <option value="">-- Виберіть предмет --</option>
                    </select>
                    <span asp-validation-for="SubjectId" class="text-danger"></span>
                </div>

                <div class="col-md-5 mb-3">
                    <label asp-for="SubjectTitle" class="form-label">Або нова назва</label>
                    <input asp-for="SubjectTitle" class="form-control" placeholder="Напр. Математика" />
                </div>
            </div>
            
            <!-- DATE AND TIME SECTION -->
            <div class="row">
                <div class="col-md-3 mb-3">
                    <label asp-for="Date" class="form-label"><span class="text-danger">*</span> Дата</label>
                    <input asp-for="Date" class="form-control" type="date" />
                    <span asp-validation-for="Date" class="text-danger"></span>
                </div>

                <div class="col-md-2 mb-3">
                    <label asp-for="StartTime" class="form-label"><span class="text-danger">*</span> Початок</label>
                    <input asp-for="StartTime" class="form-control" type="time" />
                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>

                <div class="col-md-2 mb-3">
                    <label asp-for="EndTime" class="form-label"><span class="text-danger">*</span> Кінець</label>
                    <input asp-for="EndTime" class="form-control" type="time" />
                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>

                <div class="col-md-3 mb-3">
                    <label asp-for="Place" class="form-label">Аудиторія</label>
                    <input asp-for="Place" class="form-control" placeholder="Напр. ауд. 201" />
                </div>
            </div>
            
            <!-- TEACHER AND TYPE SECTION -->
            <div class="row">
                <div class="col-md-5 mb-3">
                    <label asp-for="TeacherId" class="form-label">
                        <span class="text-danger">*</span> Викладач (вибір)
                    </label>
                    <select asp-for="TeacherId" class="form-select" asp-items="@(new Microsoft.AspNetCore.Mvc.Rendering.SelectList(Model.Teachers, "Id", "FullName", Model.TeacherId))">
                        <option value="">-- Виберіть викладача --</option>
                    </select>
                    <span asp-validation-for="TeacherId" class="text-danger"></span>
                    <small class="text-muted">Або введіть нове ім'я нижче</small>
                </div>

                <div class="col-md-5 mb-3">
                    <label asp-for="TeacherName" class="form-label">Викладач (новий)</label>
                    <input asp-for="TeacherName" class="form-control" placeholder="Напр. Петренко І.В." />
                    <small class="text-muted">Якщо вибрали викладача вище, це поле ігнорується</small>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Type" class="form-label">Тип заняття</label>
                    <select asp-for="Type" class="form-select">
                        <option value="">-- Виберіть тип --</option>
                        <option value="Lecture">Лекція</option>
                        <option value="Lab">Лабораторна</option>
                        <option value="Seminar">Семінар</option>
                        <option value="Practical">Практична</option>
                    </select>
                </div>
            </div>
            
            <!-- RECURRENCE SECTION -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <label asp-for="RecurrenceType" class="form-label">Повторення</label>
                    <select asp-for="RecurrenceType" class="form-select">
                        <option value="None">Не повторюється</option>
                        <option value="Daily">Щодня</option>
                        <option value="Weekly">Щотижня</option>
                        <option value="BiWeekly">Раз на два тижні</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="RecurrenceUntil" class="form-label">Повторювати до (дата)</label>
                    <input asp-for="RecurrenceUntil" class="form-control" type="date" />
                </div>
            </div>

            <input type="hidden" asp-for="Recurrence" />

            <button type="submit" class="btn btn-primary">Створити розклад</button>
            <a asp-action="Index" asp-controller="Calendar" class="btn btn-secondary ms-2">Назад</a>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
