@using StudentHelper.Web.Models.Schedule
@model CreateScheduleViewModel

@{
    ViewData["Title"] = "Створення розкладу";
}

<style>
    /* Уніфікація висоти: 45px для всіх елементів */
    .form-app-control {
        height: 45px !important;
        border-radius: 10px !important;
        border: 1px solid #dee2e6 !important;
    }

    /* Виправлення відступів для select */
    select.form-app-control {
        padding-top: 0 !important;
        padding-bottom: 0 !important;
    }

    /* Стиль для лейблів */
    .label-custom {
        font-weight: 700;
        color: #6c757d;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>

<div class="container mt-4">
    <div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
        <div class="card-header p-4 border-0" style="background-color: #5bc8d8;">
            <h3 class="mb-0 fw-bold text-white" style="color: white !important;">
                <i class="bi bi-calendar-plus me-2"></i> Створити розклад
            </h3>
        </div>

        <div class="card-body p-4 bg-white">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger border-0 shadow-sm mb-4" style="border-radius: 10px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                
                <div class="row g-4">
                    
                    <div class="col-md-6">
                        <label class="form-label label-custom">Група (вибір)</label>
                        <select name="GroupId" id="GroupId" class="form-select form-app-control">
                            <option value="">-- Виберіть групу --</option>
                            @if (Model.Groups != null)
                            {
                                foreach (var item in (IEnumerable<dynamic>)Model.Groups)
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            }
                        </select>
                        <small class="text-muted d-block mt-1">Або введіть нову групу нижче</small>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label label-custom">Група (нова)</label>
                        <input asp-for="GroupName" class="form-control form-app-control" placeholder="Напр. ПМІ-31" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label label-custom">Предмет</label>
                        <select name="SubjectId" id="SubjectId" class="form-select form-app-control">
                            <option value="">-- Виберіть предмет --</option>
                            @if (Model.Subjects != null)
                            {
                                foreach (var item in (IEnumerable<dynamic>)Model.Subjects)
                                {
                                    <option value="@item.Id">@item.Title</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label label-custom">Або нова назва</label>
                        <input asp-for="SubjectTitle" class="form-control form-app-control" placeholder="Напр. Математика" />
                    </div>

                    <div class="col-md-6">
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label label-custom">Дата</label>
                                <input asp-for="Date" class="form-control form-app-control" type="date" />
                            </div>
                            <div class="col-3">
                                <label class="form-label label-custom">Початок</label>
                                <input asp-for="StartTime" class="form-control form-app-control" type="time" />
                            </div>
                            <div class="col-3">
                                <label class="form-label label-custom">Кінець</label>
                                <input asp-for="EndTime" class="form-control form-app-control" type="time" />
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label label-custom">Аудиторія</label>
                        <input asp-for="Place" class="form-control form-app-control" placeholder="Напр. ауд. 201" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label label-custom">Викладач (вибір)</label>
                        <select name="TeacherId" id="TeacherId" class="form-select form-app-control">
                            <option value="">-- Виберіть викладача --</option>
                            @if (Model.Teachers != null)
                            {
                                foreach (var item in (IEnumerable<dynamic>)Model.Teachers)
                                {
                                    <option value="@item.Id">@item.FullName</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label label-custom">Викладач (новий)</label>
                        <input asp-for="TeacherName" class="form-control form-app-control" placeholder="Напр. Петренко І.В." />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label label-custom">Тип заняття</label>
                        <select asp-for="Type" class="form-select form-app-control">
                            <option value="">-- Виберіть тип --</option>
                            <option value="Lecture">Лекція</option>
                            <option value="Lab">Лабораторна</option>
                            <option value="Seminar">Семінар</option>
                            <option value="Practical">Практична</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label label-custom">Повторення</label>
                                <select asp-for="RecurrenceType" class="form-select form-app-control">
                                    <option value="None">Не повторюється</option>
                                    <option value="Daily">Щодня</option>
                                    <option value="Weekly">Щотижня</option>
                                    <option value="BiWeekly">Раз на два тижні</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label label-custom">До (дата)</label>
                                <input asp-for="RecurrenceUntil" class="form-control form-app-control" type="date" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-5 border-top pt-4">
                    <button type="submit" class="btn-app btn-app-primary">
                        <i class="bi bi-check-circle"></i> Створити розклад
                    </button>
                    <a asp-action="Index" asp-controller="Schedule" class="btn-app btn-app-back">
                        <i class="bi bi-arrow-left"></i> Назад
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}