@using StudentHelper.Web.Models.Settings;
@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Змінити пароль";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h2 class="card-title mb-4">Змінити пароль</h2>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <strong>Помилка!</strong>
                            <ul class="mb-0 mt-2">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label for="CurrentPassword" class="form-label">Поточний пароль</label>
                            <input type="password" class="form-control @(ViewData.ModelState["CurrentPassword"]?.Errors.Count > 0 ? "is-invalid" : "")" 
                                   id="CurrentPassword" name="CurrentPassword" required placeholder="Введіть поточний пароль">
                            @if (ViewData.ModelState["CurrentPassword"]?.Errors.Count > 0 && ViewData.ModelState["CurrentPassword"]?.Errors[0] != null)
                            {
                                <div class="invalid-feedback d-block">
                                    @ViewData.ModelState["CurrentPassword"]!.Errors[0].ErrorMessage
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <label for="NewPassword" class="form-label">Новий пароль</label>
                            <input type="password" class="form-control @(ViewData.ModelState["NewPassword"]?.Errors.Count > 0 ? "is-invalid" : "")" 
                                   id="NewPassword" name="NewPassword" required placeholder="Введіть новий пароль">
                            <small class="form-text text-muted d-block mt-2">
                                Пароль повинен містити мінімум 8 символів, включаючи великі та малі букви, цифри та спеціальні символи.
                            </small>
                            @if (ViewData.ModelState["NewPassword"]?.Errors.Count > 0 && ViewData.ModelState["NewPassword"]?.Errors[0] != null)
                            {
                                <div class="invalid-feedback d-block">
                                    @ViewData.ModelState["NewPassword"]!.Errors[0].ErrorMessage
                                </div>
                            }
                        </div>

                        <div class="mb-4">
                            <label for="ConfirmPassword" class="form-label">Підтвердити пароль</label>
                            <input type="password" class="form-control @(ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 ? "is-invalid" : "")" 
                                   id="ConfirmPassword" name="ConfirmPassword" required placeholder="Повторіть новий пароль">
                            @if (ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0 && ViewData.ModelState["ConfirmPassword"]?.Errors[0] != null)
                            {
                                <div class="invalid-feedback d-block">
                                    @ViewData.ModelState["ConfirmPassword"]!.Errors[0].ErrorMessage
                                </div>
                            }
                        </div>

                        <div class="d-grid gap-2 mb-3">
                            <button type="submit" class="btn btn-primary">Змінити пароль</button>
                        </div>
                        
                        <div class="text-center">
                            <a href="@Url.Action("Index", "Settings")" class="btn btn-link">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
