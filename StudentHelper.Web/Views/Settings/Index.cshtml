@using StudentHelper.Web.Models.Settings;
@model SettingsIndexViewModel
@{
    ViewData["Title"] = "Налаштування";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8">
            <h1 class="mb-4">Налаштування профілю</h1>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center bg-white">
                    <h5 class="mb-0 card-title">Особиста інформація</h5>
                    <a asp-action="EditProfile" class="btn btn-sm btn-outline-primary">Редагувати</a>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Ім'я</div>
                        <div class="col-sm-9">@Model.FirstName</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-3 text-muted">Прізвище</div>
                        <div class="col-sm-9">@Model.LastName</div>
                    </div>
                    <div class="row">
                        <div class="col-sm-3 text-muted">Email</div>
                        <div class="col-sm-9">@Model.Email</div>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-4">Безпека</h5>
                    <p class="text-muted mb-3">Керуйте безпекою вашого акаунту</p>
                    <a href="@Url.Action("ChangePassword", "Settings")" class="btn btn-primary">
                        <i class="bi bi-key"></i> Змінити пароль
                    </a>
                </div>
            </div>

            <div class="card border-danger">
                <div class="card-body">
                    <h5 class="card-title text-danger mb-4">Видалення акаунту</h5>
                    <p class="text-muted mb-3">Ця дія є незворотною. Всі ваші дані будуть назавжди видалені.</p>
                    <form asp-action="DeleteProfile" method="post" onsubmit="return confirm('Ви впевнені, що хочете назавжди видалити свій акаунт?');">
                        <button type="submit" class="btn btn-danger">Видалити акаунт</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border: none;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        border-radius: 8px;
    }

    .card-body {
        padding: 25px;
    }

    .card-header {
        padding: 20px 25px;
        border-bottom: 1px solid rgba(0,0,0,.125);
        border-radius: 8px 8px 0 0 !important;
    }

    .card-title {
        color: rgb(26, 26, 26);
        font-weight: 600;
    }

    .btn-primary {
        background-color: rgb(91, 200, 216);
        border-color: rgb(91, 200, 216);
    }

    .btn-primary:hover {
        background-color: rgb(68, 184, 200);
        border-color: rgb(68, 184, 200);
    }

    .btn-outline-primary {
        color: rgb(91, 200, 216);
        border-color: rgb(91, 200, 216);
    }

    .btn-outline-primary:hover {
        background-color: rgb(91, 200, 216);
        color: white;
        border-color: rgb(91, 200, 216);
    }
</style>