@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Успіх - Student Helper</title>
    <link rel="stylesheet" href="~/css/bundle.min.css" />
</head>
<body class="auth-page">

<div class="success-box">
    <div class="success-icon">✓</div>
    <h1>Пароль успішно змінено!</h1>
    <p>
        Ваш пароль було успішно обновлено. 
        Тепер ви можете увійти на сайт зі своїм новим паролем.
    </p>
    
    <a asp-controller="Account" asp-action="Login" class="btn-primary">Перейти до входу</a>
</div>

</body>
</html>
