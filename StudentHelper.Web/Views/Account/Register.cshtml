
@model StudentHelper.Web.Models.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Реєстрація - Student Helper</title>
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-page">

<div class="auth-box">
    <div class="auth-logo-container">
        <div class="auth-logo-header">
            <img src="/logo.png" alt="Logo" class="auth-logo" onerror="this.classList.add('auth-logo-hidden')" />
            <h1 class="auth-title">Student Helper</h1>
        </div>
    </div>

    <form asp-controller="Account" asp-action="Register" method="post">
        <div asp-validation-summary="All" class="validation-summary"></div>
        
        <div class="form-group">
            <label asp-for="FirstName"></label>
            <input asp-for="FirstName" class="form-control" placeholder="Введіть ім'я" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="LastName"></label>
            <input asp-for="LastName" class="form-control" placeholder="Введіть прізвище" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" type="email" placeholder="email@lnu.edu.ua" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password"></label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Придумайте пароль" />
            <div class="field-hint">Мінімум 8 символів, велика та мала літери, цифра та спецсимвол</div>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Повторіть пароль" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="btn-primary">Зареєструватись</button>
    </form>

    <div class="footer-links">
        Вже є акаунт? <a asp-controller="Account" asp-action="Login">Увійти</a>
    </div>
</div>

<script src="/lib/jquery/dist/jquery.min.js"></script>
<script src="/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>