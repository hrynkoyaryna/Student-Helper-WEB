@model StudentHelper.Web.Models.ResetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Скидання пароля - Student Helper</title>
    <link rel="stylesheet" href="~/css/bundle.min.css" />
</head>
<body class="auth-page">

<div class="reset-password-box">
    <div class="logo-container">
        <div style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 20px;">
            <h1 class="app-title">Student Helper</h1>
        </div>
    </div>

    <h2>Новий пароль</h2>

    <div class="info-text">
        Будь ласка, введіть новий пароль для вашого акаунту.
    </div>

    <form asp-controller="Account" asp-action="ResetPassword" method="post">
        <input type="hidden" asp-for="Code" />
        <input type="hidden" asp-for="UserId" />

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary">
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                    @foreach (var error in modelState.Errors)
                    {
                        <div>@error.ErrorMessage</div>
                    }
                }
            </div>
        }

        <div class="form-group">
            <label asp-for="Password"></label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Новий пароль" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Підтвердьте пароль" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <button type="submit" class="btn-primary">Змінити пароль</button>
    </form>

    <div class="footer-links">
        <a asp-controller="Account" asp-action="Login">← Повернутись до входу</a>
    </div>
</div>

<script src="/lib/jquery/dist/jquery.min.js"></script>
<script src="/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
