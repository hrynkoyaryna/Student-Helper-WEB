@model StudentHelper.Web.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вхід - Student Helper</title>
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body class="auth-page">

<div class="auth-box">
    <div class="auth-logo-container">
        <div class="auth-logo-header">
            <img src="/logo.png" alt="Logo" class="auth-logo" onerror="this.classList.add('auth-logo-hidden')" />
            <h1 class="auth-title">Student Helper</h1>
        </div>
    </div>

    <form asp-controller="Account" asp-action="Login" method="post">
        <div asp-validation-summary="All" class="validation-summary"></div>
        
        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" type="email" placeholder="email@lnu.edu.ua" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password"></label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Введіть пароль" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="remember-me-group">
            <input asp-for="RememberMe" type="checkbox" id="RememberMe" />
            <label for="RememberMe">Запам'ятати мене</label>
        </div>

        <button type="submit" class="btn-primary">Увійти</button>
        <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-password-link">Забули пароль?</a>
    </form>

    <div class="footer-links">
        Немає акаунту? <a asp-controller="Account" asp-action="Register">Зареєструватись</a>
    </div>
</div>

<script src="/lib/jquery/dist/jquery.min.js"></script>
<script src="/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
