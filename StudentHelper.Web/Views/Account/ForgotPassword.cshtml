@model StudentHelper.Web.Models.ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Забули пароль - Student Helper</title>
    <link rel="stylesheet" href="~/css/bundle.min.css" />
</head>
<body class="auth-page">

<div class="reset-password-box">
    <div class="logo-container">
        <div style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-bottom: 20px;">
            <h1 class="app-title">Student Helper</h1>
        </div>
    </div>

    <h2>Скидання паролю</h2>

    <div class="info-text">
        Введіть адресу електронної пошти, пов'язану з вашим акаунтом. Ми надішлемо вам посилання для скидання паролю.
    </div>

    <form asp-controller="Account" asp-action="ForgotPassword" method="post">
        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" type="email" placeholder="email@lnu.edu.ua" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <button type="submit" class="btn-primary">Надіслати посилання</button>
    </form>

    <div class="footer-links">
        <a asp-controller="Account" asp-action="Login">← Повернутись до входу</a>
    </div>
</div>

<script src="/lib/jquery/dist/jquery.min.js"></script>
<script src="/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
