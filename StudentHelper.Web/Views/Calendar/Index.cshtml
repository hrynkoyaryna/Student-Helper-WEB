@using System.Globalization
@model StudentHelper.Web.Models.Calendar.CalendarIndexViewModel

@{
    ViewData["Title"] = "Календар";
    var ukCulture = new CultureInfo("uk-UA");
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-1">
        <h1 class="calendar-page-title">Календар</h1>
        <div class="calendar-actions">
            <div class="calendar-nav-controls">
                <a asp-action="Index" asp-route-weekStartDate="@Model.WeekStartDate.AddDays(-7).ToString("yyyy-MM-dd")" class="btn btn-info text-white">←</a>
                <a asp-action="Index" asp-route-weekStartDate="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" class="btn btn-info text-white px-4">Сьогодні</a>
                <a asp-action="Index" asp-route-weekStartDate="@Model.WeekStartDate.AddDays(7).ToString("yyyy-MM-dd")" class="btn btn-info text-white">→</a>
            </div>
            <a asp-action="Create" class="btn btn-dark fw-bold py-2 px-3 shadow-sm btn-rounded">Додати подію</a>

            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Schedule" asp-action="Create" class="btn btn-primary fw-bold py-2 px-3 shadow-sm btn-rounded">Створити пару</a>
            }
        </div>
    </div>
    <p class="calendar-info-text">Тиждень: @Model.WeekStartDate.ToString("dd.MM.yyyy") — @Model.WeekEndDate.ToString("dd.MM.yyyy")</p>

    <div class="calendar-scroll-container">
        <table class="calendar-table">
            <thead>
                <tr class="text-center align-middle bg-light">
                    <th class="calendar-header-hour">Час</th>
                    @foreach (var day in Model.Days)
                    {
                        <th class="calendar-header-day">
                            <div class="calendar-header-day-name @(day == DateOnly.FromDateTime(DateTime.Today) ? "text-info" : "")">
                                @day.ToString("dddd", ukCulture)
                            </div>
                            <div class="calendar-header-day-date">@day.ToString("dd.MM")</div>
                        </th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var slot in Model.TimeSlots)
                {
                    <tr>
                        <td class="calendar-time-cell">
                            @slot.ToString("HH:mm")
                        </td>
                        @foreach (var day in Model.Days)
                        {
                            <td class="day-cell">
                                @{
                                    var eventsInSlot = Model.Events.Where(e => 
                                        DateOnly.FromDateTime(e.StartAt) == day && 
                                        TimeOnly.FromDateTime(e.StartAt).Hour == slot.Hour).ToList();
                                }

                                @if (eventsInSlot.Any())
                                {
                                    <div class="event-item-container">
                                        @foreach (var ev in eventsInSlot)
                                        {
                                            var targetController = ev.Type switch {
                                                "Task" => "Tasks",
                                                "Exam" => "Exams",
                                                _ => "Calendar"
                                            };
                                            
                                            var targetAction = "Details";

                                            <div class="event-item" 
                                                 style="background-color: @ev.Color;"
                                                 onclick="location.href='@Url.Action(targetAction, targetController, new { id = ev.Id })'">
                                                
                                                <div class="event-item-type">
                                                    @(ev.Type == "Task" ? "Завдання" : (ev.Type == "Exam" ? "Екзамен" : "Подія"))
                                                </div>

                                                <div class="event-item-title">@ev.Title</div>
                                                
                                                <div class="event-item-time">
                                                     @ev.StartAt.ToString("HH:mm") - @ev.EndAt.ToString("HH:mm")
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>