@{
    ViewData["Title"] = "Календар - Student Helper";
}

<style>
    .calendar-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .calendar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
    }

    .calendar-header h1 {
        font-size: 32px;
        font-weight: 800;
        color: rgb(26, 26, 26);
        margin: 0;
    }

    .calendar-controls {
        display: flex;
        gap: 10px;
    }

    .calendar-btn {
        padding: 10px 20px;
        background-color: rgb(91, 200, 216);
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        transition: background-color 0.3s ease;
    }

    .calendar-btn:hover {
        background-color: rgb(68, 184, 200);
    }

    .calendar-content {
        background-color: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        padding: 40px;
        text-align: center;
        min-height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .empty-state {
        text-align: center;
    }

    .empty-state-icon {
        font-size: 80px;
        margin-bottom: 20px;
        opacity: 0.3;
    }

    .empty-state h2 {
        font-size: 24px;
        font-weight: 700;
        color: rgb(113, 128, 150);
        margin-bottom: 10px;
    }

    .empty-state p {
        color: rgb(160, 174, 192);
        font-size: 16px;
    }

    @@media (max-width: 768px) {
        .calendar-header {
            flex-direction: column;
            gap: 20px;
            align-items: flex-start;
        }

        .calendar-header h1 {
            font-size: 24px;
        }

        .calendar-controls {
            width: 100%;
        }

        .calendar-content {
            padding: 20px;
            min-height: 300px;
        }

        .empty-state-icon {
            font-size: 60px;
        }

        .empty-state h2 {
            font-size: 18px;
        }
    }
</style>

<div class="calendar-container">
    <div class="calendar-header">
        <h1>📅 Календар</h1>
        <div class="calendar-controls">
            <button class="calendar-btn">← Назад</button>
            <button class="calendar-btn">Сьогодні</button>
            <button class="calendar-btn">Вперед →</button>
        </div>
    </div>

    <div class="calendar-content">
        <div class="empty-state">
            <div class="empty-state-icon">📅</div>
            <h2>Календар розробляється</h2>
            <p>Ця сторінка буде розроблена найближчим часом</p>
        </div>
    </div>
</div>
