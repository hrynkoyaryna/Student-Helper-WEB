@model StudentHelper.Domain.Entities.PersonalEvent

@{
    ViewData["Title"] = "Деталі події - Student Helper";
}

<style>
    .calendar-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 32px 20px 48px;
    }

    .details-shell {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        border: 1px solid #e5e7eb;
        padding: 40px;
    }

    .details-header {
        margin-bottom: 24px;
        border-bottom: 2px solid #f1f5f9;
        padding-bottom: 16px;
    }

    .details-title {
        font-size: 32px;
        font-weight: 800;
        color: #1a1a1a;
        margin: 0;
    }

    .details-group {
        margin-bottom: 24px;
    }

    .details-label {
        display: block;
        font-size: 14px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        margin-bottom: 8px;
    }

    .details-value {
        font-size: 18px;
        color: #1e293b;
        line-height: 1.6;
    }

    .time-badge {
        display: inline-flex;
        align-items: center;
        background-color: #dff7fb;
        color: #0369a1;
        padding: 6px 16px;
        border-radius: 9999px;
        font-weight: 600;
        font-size: 15px;
        border: 1px solid #5bc8d8;
    }

    .description-box {
        background-color: #f8fafc;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        white-space: pre-wrap; /* Зберігає перенесення рядків, які ввів користувач */
    }

    .details-actions {
        display: flex;
        gap: 12px;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid #e5e7eb;
        align-items: center;
    }

    .btn-back {
        background-color: #f1f5f9;
        color: #475569;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 700;
        transition: 0.2s;
        display: inline-flex;
        align-items: center;
    }

    .btn-back:hover {
        background-color: #e2e8f0;
        color: #1e293b;
    }

    .btn-delete {
        background-color: #ef4444;
        color: white;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 700;
        transition: 0.2s;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
    }

    .btn-delete:hover {
        background-color: #dc2626;
    }

    .btn-edit {
        background-color: #111827;
        color: white;
        text-decoration: none;
        padding: 12px 24px;
        border-radius: 10px;
        font-weight: 700;
        transition: 0.2s;
        display: inline-flex;
        align-items: center;
    }

    .btn-edit:hover {
        background-color: #1f2937;
    }
</style>

<div class="calendar-container">
    <div class="details-shell">
        <div class="details-header">
            <h1 class="details-title">@Model.Title</h1>
        </div>

        <div class="details-group">
            <span class="details-label">Дата та час</span>
            <div class="details-value">
                <span class="time-badge">
                    @Model.StartAt.ToString("dd.MM.yyyy") | 
                    @Model.StartAt.ToString("HH:mm") — @Model.EndAt.ToString("HH:mm")
                </span>
            </div>
        </div>

        <div class="details-group">
            <span class="details-label">Опис події</span>
            <div class="details-value">
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <div class="description-box">@Model.Description</div>
                }
                else
                {
                    <span style="color: #94a3b8; font-style: italic;">Опис відсутній</span>
                }
            </div>
        </div>

        <div class="details-actions">
            <a asp-action="Index" class="btn-back">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 8px;">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Назад до календаря
            </a>
            
            @* НОВА КНОПКА РЕДАГУВАННЯ *@
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
                Редагувати
            </a>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити цю подію? Цю дію неможливо скасувати.');" style="margin: 0;">
                <button type="submit" class="btn-delete">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    </svg>
                    Видалити
                </button>
            </form>
        </div>
    </div>
</div>