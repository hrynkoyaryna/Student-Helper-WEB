@model StudentHelper.Domain.Entities.PersonalEvent

@{
    ViewData["Title"] = "Деталі події";
    
    // Формуємо рядок часу заздалегідь, щоб Razor не плутався в символах
    var dateString = Model?.StartAt.ToString("dd.MM.yyyy") ?? "";
    var timeString = Model != null ? $"{Model.StartAt:HH:mm} — {Model.EndAt:HH:mm}" : "";
}

<div class="calendar-container-details">
    <div class="details-shell">
        <div class="details-header">
            <h1 class="details-title">@(Model?.Title ?? "Без назви")</h1>
        </div>

        <div class="details-body">
            <div class="details-group">
                <span class="details-label">Дата та час</span>
                <div class="details-value">
                    <span class="time-badge">
                        <i class="bi bi-clock-fill me-2"></i>
                        @dateString | @timeString
                    </span>
                </div>
            </div>

            <div class="details-group">
                <span class="details-label">Опис події</span>
                <div class="details-value">
                    @if (Model != null && !string.IsNullOrWhiteSpace(Model.Description))
                    {
                        <div class="description-box">@Model.Description</div>
                    }
                    else
                    {
                        <span class="text-muted" style="font-style: italic;">Опис відсутній</span>
                    }
                </div>
            </div>
        </div>

        <div class="details-actions">
            <div class="d-flex flex-wrap gap-2">
                <a asp-action="Index" class="btn-unified btn-back">
                    <i class="bi bi-arrow-left"></i> Назад
                </a>
                
                @if (Model != null)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-unified btn-edit">
                        <i class="bi bi-pencil-square"></i> Редагувати
                    </a>

                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" 
                          onsubmit="return confirm('Ви впевнені?');" class="m-0 p-0" style="display:inline-block;">
                        <button type="submit" class="btn-unified btn-delete">
                            <i class="bi bi-trash"></i> Видалити
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/calendar.css" asp-append-version="true" />
}