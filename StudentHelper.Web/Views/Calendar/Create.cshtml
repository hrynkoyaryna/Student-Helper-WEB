@model StudentHelper.Web.Models.Calendar.CreatePersonalEventViewModel

@{
    ViewData["Title"] = "Додати подію";
}

<div class="create-event-container">
    <div class="create-event-card">
        <h1 class="create-event-title">Додати нову подію</h1>

        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
            }

            <div class="form-group">
                <label asp-for="Title">Назва події</label>
                <input asp-for="Title" class="form-control" placeholder="Наприклад: Лекція з програмування" />
                <span asp-validation-for="Title" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description">Опис</label>
                <textarea asp-for="Description" class="form-control" placeholder="Деталі події..."></textarea>
                <span asp-validation-for="Description" class="validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Date">Дата</label>
                    <input asp-for="Date" type="date" class="form-control" />
                    <span asp-validation-for="Date" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="StartTime">Час початку</label>
                    <input asp-for="StartTime" type="time" class="form-control" />
                    <span asp-validation-for="StartTime" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EndTime">Час завершення</label>
                    <input asp-for="EndTime" type="time" class="form-control" />
                    <span asp-validation-for="EndTime" class="validation-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Color">Колір події</label>
                <div style="display: flex; align-items: center; gap: 15px;">
                    <input asp-for="Color" type="color" value="@Model.Color" />
                    <span style="color: var(--text-muted); font-size: 0.9rem;">Оберіть колір для календаря</span>
                </div>
                <span asp-validation-for="Color" class="validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="action-btn save-btn">Створити подію</button>
                <a asp-action="Index" class="action-btn cancel-btn">Скасувати</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}