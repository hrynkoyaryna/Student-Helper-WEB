@model StudentHelper.Web.Models.Calendar.EditPersonalEventViewModel

@{
    ViewData["Title"] = "Редагування події";
}

<div class="create-event-container">
    <div class="create-event-card">
        <h1 class="create-event-title">Редагування події</h1>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>

            <div class="form-group">
                <label asp-for="Title">Назва події</label>
                <input asp-for="Title" />
                <span asp-validation-for="Title" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description">Опис</label>
                <textarea asp-for="Description"></textarea>
                <span asp-validation-for="Description" class="validation-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Date">Дата</label>
                    <input asp-for="Date" type="date" />
                    <span asp-validation-for="Date" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="StartTime">Час початку</label>
                    <input asp-for="StartTime" type="time" />
                    <span asp-validation-for="StartTime" class="validation-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="EndTime">Час завершення</label>
                    <input asp-for="EndTime" type="time" />
                    <span asp-validation-for="EndTime" class="validation-error"></span>
                </div>
            </div>

            <div class="form-group" style="max-width: 150px;">
                <label asp-for="Color">Колір події</label>
                <input asp-for="Color" type="color" value="@Model.Color" style="height: 45px; padding: 2px; cursor: pointer;"/>
                <span asp-validation-for="Color" class="validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="action-btn save-btn">Зберегти зміни</button>
                <a asp-action="Index" class="btn-app btn-app-cancel">
                    <i class="bi bi-x-circle"></i> Скасувати
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}