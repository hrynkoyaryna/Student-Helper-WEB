@model StudentHelper.Web.Models.Notes.NotesIndexViewModel

@{
    ViewData["Title"] = "Мої нотатки";
}

<div style="display: none;">
    @Html.AntiForgeryToken()
</div>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-4">
                <i class="fas fa-sticky-note"></i> Мої нотатки
            </h1>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Create", "Notes")" class="btn btn-primary">
                <i class="fas fa-plus"></i> Нова нотатка
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Пошук -->
    <div class="row mb-4">
        <div class="col-md-6">
            <form method="get" class="input-group">
                <input type="text" name="search" class="form-control" 
                       placeholder="Пошук нотаток..." 
                       value="@Model.SearchQuery"
                       aria-label="Пошук нотаток">
                <button class="btn btn-outline-secondary" type="submit">
                    <i class="fas fa-search"></i> Пошук
                </button>
                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                {
                    <a href="@Url.Action("Index", "Notes")" class="btn btn-outline-secondary">
                        <i class="fas fa-times"></i> Очистити
                    </a>
                }
            </form>
        </div>
    </div>

    <!-- Нотатки -->
    @if (Model.Notes.Any())
    {
        <!-- Закріплені нотатки -->
        @if (Model.Notes.Any(n => n.Pinned))
        {
            <div class="mb-5">
                <h5 class="mb-3">
                    <i class="fas fa-thumbtack text-warning"></i> Закріплені
                </h5>
                <div class="row">
                    @foreach (var note in Model.Notes.Where(n => n.Pinned))
                    {
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100 shadow-sm border-warning note-card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title mb-0">@note.Title</h5>
                                        <div class="note-actions">
                                            <button type="button" class="btn btn-sm btn-warning unpin-btn" 
                                                    data-note-id="@note.Id" title="Відкріпити">
                                                <i class="fas fa-thumbtack"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <p class="card-text text-muted" style="min-height: 80px; max-height: 150px; overflow: auto;">
                                        @note.Body
                                    </p>
                                    <div class="btn-group w-100" role="group">
                                        <a href="@Url.Action("Edit", "Notes", new { id = note.Id })" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-edit"></i> Редагувати
                                        </a>
                                        <form method="post" action="@Url.Action("Delete", "Notes")" 
                                              class="d-inline" onsubmit="return confirm('Ви впевнені?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@note.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                                <i class="fas fa-trash"></i> Видалити
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Інші нотатки -->
        @if (Model.Notes.Any(n => !n.Pinned))
        {
            <div class="mb-5">
                <h5 class="mb-3">
                    <i class="fas fa-file-alt text-secondary"></i> Всі нотатки
                </h5>
                <div class="row">
                    @foreach (var note in Model.Notes.Where(n => !n.Pinned))
                    {
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100 shadow-sm note-card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h5 class="card-title mb-0">@note.Title</h5>
                                        <div class="note-actions">
                                            <button type="button" class="btn btn-sm btn-outline-warning pin-btn" 
                                                    data-note-id="@note.Id" title="Закріпити">
                                                <i class="fas fa-thumbtack"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <p class="card-text text-muted" style="min-height: 80px; max-height: 150px; overflow: auto;">
                                        @note.Body
                                    </p>
                                    <div class="btn-group w-100" role="group">
                                        <a href="@Url.Action("Edit", "Notes", new { id = note.Id })" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-edit"></i> Редагувати
                                        </a>
                                        <form method="post" action="@Url.Action("Delete", "Notes")" 
                                              class="d-inline" onsubmit="return confirm('Ви впевнені?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@note.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100">
                                                <i class="fas fa-trash"></i> Видалити
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i>
            @if (string.IsNullOrEmpty(Model.SearchQuery))
            {
                <p>У вас немає жодної нотатки. <a href="@Url.Action("Create", "Notes")">Створіть першу нотатку!</a></p>
            }
            else
            {
                <p>Не знайдено нотаток, які відповідають запиту "<strong>@Model.SearchQuery</strong>"</p>
            }
        </div>
    }
</div>

<style>
    .note-card {
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
    }

    .note-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    .note-actions {
        display: flex;
        gap: 5px;
    }

    .btn-group {
        display: flex;
    }

    .btn-group .btn {
        flex: 1;
        border-radius: 0;
    }

    .btn-group .btn:first-child {
        border-top-left-radius: 0.375rem;
        border-bottom-left-radius: 0.375rem;
    }

    .btn-group .btn:last-child {
        border-top-right-radius: 0.375rem;
        border-bottom-right-radius: 0.375rem;
    }

    .btn-group form {
        width: 100%;
    }

    .btn-group form .btn {
        width: 100%;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Get antiforgery token from the hidden input
        const antiForgeryInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const antiForgeryToken = antiForgeryInput ? antiForgeryInput.value : '';

        // Pin buttons
        document.querySelectorAll('.pin-btn').forEach(btn => {
            btn.addEventListener('click', async function () {
                const noteId = this.getAttribute('data-note-id');
                try {
                    const response = await fetch(`@Url.Action("Pin", "Notes")?id=${noteId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': antiForgeryToken,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    if (response.ok) {
                        location.reload();
                    }
                } catch (err) {
                    console.error('Error:', err);
                }
            });
        });

        // Unpin buttons
        document.querySelectorAll('.unpin-btn').forEach(btn => {
            btn.addEventListener('click', async function () {
                const noteId = this.getAttribute('data-note-id');
                try {
                    const response = await fetch(`@Url.Action("Unpin", "Notes")?id=${noteId}`, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': antiForgeryToken,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    if (response.ok) {
                        location.reload();
                    }
                } catch (err) {
                    console.error('Error:', err);
                }
            });
        });
    });
</script>
