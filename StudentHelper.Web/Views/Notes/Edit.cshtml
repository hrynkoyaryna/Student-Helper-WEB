@model StudentHelper.Web.Models.Notes.NoteCreateEditViewModel

@{
    ViewData["Title"] = "Редагувати нотатку";
    int noteId = (int)(ViewBag.NoteId ?? 0);
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 class="mb-4">
                <i class="fas fa-sticky-note"></i> Редагувати нотатку
            </h1>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form method="post" action="@Url.Action("Edit", "Notes", new { id = noteId })">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@noteId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label">
                                Заголовок <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" type="text" class="form-control" placeholder="Введіть заголовок нотатки" required>
                            <span asp-validation-for="Title" class="text-danger"></span>
                            <small class="form-text text-muted">Максимум 200 символів</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Body" class="form-label">
                                Текст нотатки <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Body" rows="8" class="form-control" placeholder="Введіть текст нотатки..." required></textarea>
                            <span asp-validation-for="Body" class="text-danger"></span>
                            <small class="form-text text-muted">Максимум 5000 символів</small>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("Index", "Notes")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Скасувати
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Зберегти зміни
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        border-color: #80bdff;
        box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    }

    textarea.form-control {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        resize: vertical;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
