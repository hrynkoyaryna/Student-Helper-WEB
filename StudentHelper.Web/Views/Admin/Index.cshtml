@model IEnumerable<StudentHelper.Domain.Entities.Group>
<div class="container mt-5">
    <div class="card shadow-sm p-4" style="border-radius: 15px;">
        <h3 class="mb-4">Керування групами</h3>
        
        <!-- Форма створення -->
        <form asp-action="CreateGroup" method="post" class="mb-4">
            <div class="input-group">
                <input type="text" name="name" class="form-control" placeholder="Назва групи (напр. Гр-33)" required>
                <button class="btn text-white" type="submit" style="background-color: rgb(91, 200, 216);">Створити</button>
            </div>
        </form>

        <!-- Список існуючих груп -->
        <table class="table">
            <thead>
                <tr><th>ID</th><th>Назва</th></tr>
            </thead>
            <tbody>
                @foreach(var g in Model) {
                    <tr><td>@g.Id</td><td>@g.Name</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>