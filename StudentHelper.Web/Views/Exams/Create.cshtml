@model StudentHelper.Web.Models.Exams.ExamCreateEditViewModel

@{
    ViewData["Title"] = "Додати екзамен";
}

<div class="container mt-5">
    <h1>Додати екзамен</h1>

    <form method="post" asp-action="Create">
        <div class="mb-3">
            <label class="form-label">Предмет</label>
            <input asp-for="Subject" class="form-control" />
            <span asp-validation-for="Subject" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Дата та час</label>
            <input asp-for="DateTime" type="datetime-local" class="form-control" value="@(Model.DateTime.ToString("yyyy-MM-ddTHH:mm"))" />
            <span asp-validation-for="DateTime" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Викладач (виберіть зі списку або введіть власноруч)</label>
            <select asp-for="TeacherId" class="form-select mb-2">
                <option value="">-- оберіть викладача --</option>
                @foreach(var t in Model.Teachers)
                {
                    <option value="@t.Id" selected="@(t.Id == Model.TeacherId ? "selected" : null)">@t.FullName</option>
                }
            </select>
            <input asp-for="TeacherName" class="form-control" placeholder="Введіть ПІБ викладача" />
            <span asp-validation-for="TeacherId" class="text-danger"></span>
            <span asp-validation-for="TeacherName" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Створити</button>
        <a asp-action="Index" class="btn btn-link">Скасувати</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
