@model StudentHelper.Web.Models.Exams.ExamIndexViewModel

@{
    ViewData["Title"] = "Екзамени";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="exams-page-header">📚 Екзамени</h1>
        <div>
            @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-primary px-4 shadow-sm btn-rounded">Додати екзамен</a>
            }
            @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
            {
                <a asp-action="CreateGroupExam" class="btn btn-success px-4 shadow-sm ms-2 btn-rounded">Додати екзамен для групи</a>
            }
        </div>
    </div>

    <div class="exams-container">
        <div class="exams-filter-buttons">
            <a asp-action="Index" asp-route-time="all" asp-route-subject="@Model.SelectedSubject" asp-route-sort="@Model.SortOrder"
               class="btn @(Model.TimeFilter == "all" ? "btn-primary" : "btn-outline-primary") exams-filter-btn">Усі</a>
            <a asp-action="Index" asp-route-time="upcoming" asp-route-subject="@Model.SelectedSubject" asp-route-sort="@Model.SortOrder"
               class="btn @(Model.TimeFilter == "upcoming" ? "btn-primary" : "btn-outline-primary") exams-filter-btn">Майбутні</a>
            <a asp-action="Index" asp-route-time="past" asp-route-subject="@Model.SelectedSubject" asp-route-sort="@Model.SortOrder"
               class="btn @(Model.TimeFilter == "past" ? "btn-primary" : "btn-outline-primary") exams-filter-btn">Минулі</a>
        </div>

        <form method="get" asp-action="Index" class="exams-form">
            <input type="hidden" name="time" value="@Model.TimeFilter" />
            <input type="hidden" name="sort" value="@Model.SortOrder" />

            <div class="flex-grow-1" style="min-width: 200px;">
                <label class="form-label fw-semibold">Предмет</label>
                <select name="subject" class="form-select">
                    <option value="">Усі предмети</option>
                    @foreach (var subject in Model.Subjects)
                    {
                        <option value="@subject" selected="@(Model.SelectedSubject == subject)">@subject</option>
                    }
                </select>
            </div>

            <div>
                <button type="submit" class="btn btn-primary px-4 btn-rounded">Фільтрувати</button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4 btn-rounded">Скинути</a>
            </div>
        </form>

        @if (!Model.Exams.Any())
        {
            <div class="exams-empty-state">
                <h5>Немає екзаменів</h5>
                <p>Додай новий екзамен або зміни фільтр.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var exam in Model.Exams)
                {
                    <div class="col-12">
                        <div class="exam-card">
                            <div class="exam-card-header">
                                <div>
                                    <h4 class="exam-subject">
                                        @exam.Subject
                                        @if (exam.GroupId.HasValue)
                                        {
                                            <span class="badge exam-subject-badge">Групповий</span>
                                        }
                                    </h4>
                                    <div class="exam-info">
                                        <span></span><strong>Дата:</strong> @exam.DateTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                    <div class="exam-info">
                                        <span></span><strong>Викладач:</strong> @(string.IsNullOrEmpty(exam.TeacherName) ? "Не вказано" : exam.TeacherName)
                                    </div>
                                </div>

                                <div class="exam-actions">
                                    <a asp-action="Details" asp-route-id="@exam.Id" class="btn btn-outline-secondary btn-sm exam-action-btn">Деталі</a>
                                    @if (exam.GroupId == null)
                                    {
                                        <a asp-action="Edit" asp-route-id="@exam.Id" class="btn btn-outline-primary btn-sm exam-action-btn">Редагувати</a>
                                        <a asp-action="Delete" asp-route-id="@exam.Id" class="btn btn-outline-danger btn-sm exam-action-btn">Видалити</a>
                                    }
                                    else if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                                    {
                                        <a asp-action="EditGroupExam" asp-route-id="@exam.Id" class="btn btn-outline-primary btn-sm exam-action-btn">Редагувати</a>
                                        <a asp-action="Delete" asp-route-id="@exam.Id" class="btn btn-outline-danger btn-sm exam-action-btn">Видалити</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>