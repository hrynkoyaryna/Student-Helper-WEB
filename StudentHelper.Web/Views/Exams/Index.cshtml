@model StudentHelper.Web.Models.Exams.ExamIndexViewModel

@{
    ViewData["Title"] = "Екзамени";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 style="font-size: 32px; font-weight: 800; color: rgb(26, 26, 26);">📚 Екзамени</h1>
        <a asp-action="Create" class="btn btn-primary px-4">Додати екзамен</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-4 shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="bg-white rounded-4 shadow-sm p-4">
        <div class="d-flex flex-wrap gap-2 mb-4">
            <a asp-action="Index" asp-route-time="all" asp-route-subject="@Model.SelectedSubject" asp-route-sort="@Model.SortOrder"
               class="btn @(Model.TimeFilter == "all" ? "btn-primary" : "btn-outline-primary")">Усі</a>
            <a asp-action="Index" asp-route-time="upcoming" asp-route-subject="@Model.SelectedSubject" asp-route-sort="@Model.SortOrder"
               class="btn @(Model.TimeFilter == "upcoming" ? "btn-primary" : "btn-outline-primary")">Майбутні</a>
            <a asp-action="Index" asp-route-time="past" asp-route-subject="@Model.SelectedSubject" asp-route-sort="@Model.SortOrder"
               class="btn @(Model.TimeFilter == "past" ? "btn-primary" : "btn-outline-primary")">Минулі</a>
        </div>

        <form method="get" asp-action="Index" class="row g-3 align-items-end mb-4">
            <input type="hidden" name="time" value="@Model.TimeFilter" />
            <input type="hidden" name="sort" value="@Model.SortOrder" />

            <div class="col-md-4">
                <label class="form-label fw-semibold">Предмет</label>
                <select name="subject" class="form-select">
                    <option value="">Усі предмети</option>
                    @foreach (var subject in Model.Subjects)
                    {
                        if (Model.SelectedSubject == subject)
                        {
                            <option value="@subject" selected>@subject</option>
                        }
                        else
                        {
                            <option value="@subject">@subject</option>
                        }
                    }
                </select>
            </div>

            

            <div class="col-md-auto">
                <button type="submit" class="btn btn-primary">Фільтрувати</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Скинути</a>
            </div>
        </form>

        @if (!Model.Exams.Any())
        {
            <div class="text-center py-5 text-secondary">
                <h5 class="mb-2">Немає екзаменів</h5>
                <p class="mb-0">Додай новий екзамен або зміни фільтр.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var exam in Model.Exams)
                {
                    <div class="col-12">
                        <div class="border rounded-4 p-4 shadow-sm">
                            <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                                <div>
                                    <h4 class="mb-2">@exam.Subject</h4>
                                    <div class="text-secondary mb-1">
                                        <strong>Дата:</strong> @exam.DateTime.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                    <div class="text-secondary mb-1">
                                        <strong>Викладач:</strong> @(exam.Teacher != null ? exam.Teacher.FullName : "—")
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap gap-2 align-items-start">
                                    <a asp-action="Details" asp-route-id="@exam.Id" class="btn btn-outline-secondary btn-sm">Деталі</a>
                                    <a asp-action="Edit" asp-route-id="@exam.Id" class="btn btn-outline-primary btn-sm">Редагувати</a>
                                    <a asp-action="Delete" asp-route-id="@exam.Id" class="btn btn-outline-danger btn-sm">Видалити</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
