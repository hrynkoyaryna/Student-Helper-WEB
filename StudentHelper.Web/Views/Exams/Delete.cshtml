@model StudentHelper.Domain.Entities.Exam

@{
    ViewData["Title"] = "Видалити екзамен";
}

<div class="container mt-5">
    <h1>Видалити екзамен</h1>

    <div class="alert alert-warning">Ви дійсно хочете видалити цей екзамен?</div>

    <dl class="row">
        <dt class="col-sm-3">Предмет</dt>
        <dd class="col-sm-9">@Model.Subject</dd>

        <dt class="col-sm-3">Дата та час</dt>
        <dd class="col-sm-9">@Model.DateTime.ToString("dd.MM.yyyy HH:mm")</dd>

        <dt class="col-sm-3">Викладач</dt>
        <dd class="col-sm-10">@Model.TeacherName</dd>
    </dl>

    <form method="post" asp-action="DeleteConfirmed" asp-route-id="@Model.Id">
        <button type="submit" class="btn btn-danger">Видалити</button>
        <a asp-action="Index" class="btn btn-link">Скасувати</a>
    </form>
</div>
