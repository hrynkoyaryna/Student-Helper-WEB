@model StudentHelper.Web.Models.ErrorViewModel

@{
    ViewData["Title"] = Model.Title;
}

<body class="error-page">
    <div class="error-container">
        <div class="text-center">
            <!-- Велика цифра статусу -->
            <div class="error-status-code">
                @Model.StatusCode
            </div>

            <!-- Заголовок помилки -->
            <h1 class="error-title">
                @Model.Title
            </h1>

            <!-- Повідомлення про помилку -->
            <p class="error-message">
                @Model.Message
            </p>

            <!-- Кнопки навігації -->
            <div class="error-actions">
                <a href="/" class="error-btn error-btn-primary">
                    🏠 На головну
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a href="/Calendar" class="error-btn error-btn-outline">
                        📅 На календар
                    </a>
                }
            </div>

            <!-- Технічна інформація -->
            @if (Model.ShowRequestId)
            {
                <div class="error-request-id">
                    <p class="text-muted small mb-0">
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    </p>
                </div>
            }

            <!-- Додаткова інформація -->
            <div class="error-footer-text">
                <p>Якщо проблема зберігається, будь ласка свяжіться з підтримкою.</p>
            </div>
        </div>
    </div>
</body>
